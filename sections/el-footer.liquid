{%- style -%}
.el-section-bg-{{ section.id }} {
    background-color:{{ section.settings.background_color }};
    color:{{ section.settings.text_color }};
    }
{% if section.settings.background_image != blank %}
.el-section-bg-{{ section.id }} {
      background-image:url({{section.settings.background_image | image_url}});
    background-size: cover;
    background-attachment: unset;
    background-repeat: no-repeat;
    background-position: center;
    }
  {% endif %}
{% if section.settings.background_image_mobile != blank %}
  @media screen and (max-width: 915px) {
    .el-section-bg-{{ section.id }} {
      background-image:url({{section.settings.background_image_mobile | image_url}});
    }
  }
  {% endif %}
  @media screen and (max-width: 915px) {
    .el-section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
  @media screen and (min-width: 915px) {
    .el-section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }  
{%- endstyle -%}
<div class="el-section-bg-{{ section.id }} el-footer {{ section.settings.custom_class }}" {% if section.settings.custom_id != blank %} id="{{ section.settings.custom_id }}" {% endif %}>
  <div class="el-container el-section-{{ section.id }}-padding">
    <div class="el-footer-content el-text-{{ section.settings.text_alignment }}-desktop el-text-{{ section.settings.text_alignment_mobile }}-mobile"> 
        {%- for block in section.blocks -%} 
            {%- case block.type -%} 
                {%- when 'logo' -%} 
                    {%  render 'el-element-logo', block:block %} 
                {%- when 'image' -%} 
                    {%  render 'el-element-image', block:block %} 
                {%- when 'liquid' -%} 
                    {%  render 'el-element-liquid', block:block %} 
                {%- when 'menu' -%} 
                    {%  render 'el-element-menu', block:block %} 
                {%- when 'richtext' -%} 
                    {%  render 'el-element-richtext', block:block %} 
                {%- when 'icon_with_text' -%} 
                    {%  render 'el-element-icon-with-text', block:block %} 
            {%  endcase %}
        {%  endfor %} 
    </div>
  </div>
</div>
