<div class="el-element el-element-review-card {{ block.settings.custom_class }} el-element-{{ block.id }}"{% if block.settings.custom_id != blank %} id="{{ block.settings.custom_id }}"{% endif %}>
<div class="el-review-card_main">
<div class="el-element-review-card-top">
{% if block.settings.image_mobile != blank %}
  <div class="el-media el-hide-mobile">
 {{ block.settings.image | image_url: width: 800 | image_tag:
  loading: block.settings.image_loading,
  fetchpriority: block.settings.image_performance,
  alt:block.settings.image.alt,
  widths: '375, 550, 750, 800'
}}   
</div>
  <div class="el-media el-hide-desktop">
 {{ block.settings.image_mobile | image_url: width: 800 | image_tag:
  loading: block.settings.image_loading,
  fetchpriority: block.settings.image_performance,
  alt:block.settings.image_mobile.alt,
  widths: '375, 550, 750, 800'
}}   
</div>
{% else %}
  <div class="el-media">
 {{ block.settings.image | image_url: width: 800 | image_tag:
  loading: block.settings.image_loading,
  fetchpriority: block.settings.image_performance,
  alt:block.settings.image.alt,
  widths: '375, 550, 750, 800'
}} 
</div>
{%  endif %}
{%  if block.settings.rating != blank or block.settings.rating_icon != blank %}
<div class="el-element-review-rating">
<div class="el-element-review-rating-{{ block.id }} el-review-card-rating el-element">
{{  block.settings.rating_icon }}<span>{{  block.settings.rating }}</span></div>
</div>
{% endif %}
{%  if block.settings.title != blank %}
<div class="el-element-title-main">
<div class="el-element-title-{{ block.id }} el-review-card-title el-element el-font-body">{{  block.settings.title }}</div>
</div>
{% endif %}
{%  if block.settings.text != blank %}
<div class="el-element-text-main">
<div class="el-element-text-{{ block.id }} el-review-card-text el-element el-font-body">{{  block.settings.text }}</div>
</div>
{% endif %}
</div>
<div class="el-element-review-card-bottom">
{%  if block.settings.name != blank %}
<div class="el-element-review-user-detail">
<div class="el-element-review-name">
{{  block.settings.verified_badge }}<span>{{  block.settings.name }}</span>
</div>
</div>

{% endif %}
</div>
</div>
</div>